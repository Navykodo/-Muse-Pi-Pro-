# ZeroClaw Web/voice bridge runtime configuration example.
# Copy to .env or export these variables on the target machine.

ZEROCLAW_AGENT=default
ZEROCLAW_WS_URL=ws://127.0.0.1:42617/ws/chat?agent=default
HARDWARE_API_TOOL_URL=http://127.0.0.1:8765/tool

C6_DAEMON_BIN=
SHERPA_ASR_DIR=
SHERPA_OFFLINE_WS_URL=ws://127.0.0.1:6006

ZEROCLAW_WEB_HOST=0.0.0.0
ZEROCLAW_WEB_PORT=8795

XFYUN_TTS_ENABLED=1
XFYUN_TTS_APPID=
XFYUN_TTS_API_SECRET=
XFYUN_TTS_API_KEY=
